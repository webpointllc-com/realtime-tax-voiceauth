# Copy to .deploy.env (gitignored) AFTER you create the Render service once.
# Get the deploy hook: Render -> realtime-tax-app -> Settings -> Deploy Hook.
RENDER_DEPLOY_HOOK_URL=
# OR use the API instead of a hook:
# RENDER_API_KEY=
# RENDER_SERVICE_ID=
APP_URL=https://realtime-tax-app.onrender.com
